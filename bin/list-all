#!/usr/bin/env bash

# See: https://kvz.io/bash-best-practices.html
set -o errexit
set -o nounset
set -o pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "${current_script_path}")")

# shellcheck source=./lib/utils.sh
source "${plugin_dir}/lib/utils.sh"

########
# MAIN #
########

list_all_versions
